<!-- Supabase JavaScript client library -->
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>

<script>
  /* ========== Supabase config ==========
     These values are safe to publish — Row Level Security in the DB
     controls what they're allowed to do. The publishable key only has the
     permissions we explicitly grant via RLS policies.
  */
  const SUPABASE_URL = 'https://kikvckuaorpspxhtnpzd.supabase.co';
  const SUPABASE_KEY = 'sb_publishable_FsuRAVFjLNQ1q650FHw2cA_UhtakskW';

  // Defensive: if the Supabase library failed to load (ad-blocker, CDN issue, file:// origin),
  // show a clear message in the listings grid instead of staying stuck on "Loading…".
  if (typeof window.supabase === 'undefined' || !window.supabase.createClient) {
    function showLibraryError() {
      const grid = document.getElementById('cards-grid');
      if (grid) {
        grid.innerHTML = '<p class="no-results">Could not load the Supabase library. If you\'re viewing this file locally (file://), please open the live site at https://geosin.be/services.html instead. If you\'re on the live site, check that no ad-blocker or browser extension is blocking cdn.jsdelivr.net.</p>';
      }
      const countEl = document.getElementById('results-count');
      if (countEl) countEl.textContent = 'Service listing temporarily unavailable.';
    }
    // The script is at the end of <body> so the DOM is already parsed; call directly.
    showLibraryError();
    throw new Error('Supabase library not loaded — see grid for details.');
  }

  const supabase = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

  /* ========== Mappings ==========
     The DB stores categories and regions as free-form text (matching the
     dropdown values). The filter UI uses short slug keys ("legal", "brussels"),
     so we map between them.
  */
  const CAT_TO_SLUG = {
    'Legal & admin': 'legal',
    'Translation': 'translation',
    'Health & wellness': 'health',
    'Education & tuition': 'education',
    'Food & catering': 'food',
    'Property & housing': 'property',
    'Beauty & care': 'beauty',
    'Transport': 'transport',
    'IT & tech': 'it',
    'Finance & tax': 'finance',
    'Other': 'other'
  };
  function regionToSlug(region) {
    const r = (region || '').toLowerCase();
    if (r.includes('brussel') || r.includes('bruxelles')) return 'brussels';
    if (r.includes('antwerp')) return 'antwerp';
    if (r.includes('ghent') || r.includes('gent')) return 'ghent';
    if (r.includes('liège') || r.includes('liege')) return 'liege';
    if (r.includes('bruges') || r.includes('brugge')) return 'bruges';
    if (r.includes('remote') || r.includes('online') || r.includes('any')) return 'remote';
    return 'other';
  }

  /* ========== Language toggle (shared across pages) ========== */
  function setLang(lang) {
    localStorage.setItem('geosin-lang', lang);
    document.querySelectorAll('.lang-btn').forEach(b => b.classList.toggle('active', b.dataset.lang === lang));
    document.querySelectorAll('[data-lang-block]').forEach(el => {
      el.style.display = el.dataset.langBlock === lang ? '' : 'none';
    });
    document.documentElement.lang = lang === 'ka' ? 'ka' : 'en';
  }

  /* ========== Mobile nav ========== */
  function toggleMobileNav() {
    document.getElementById('site-nav').classList.toggle('nav-mobile-open');
  }

  /* ========== Listings ========== */
  let allServices = [];
  let currentCat = 'all';

  function escapeHtml(str) {
    return String(str == null ? '' : str).replace(/[<>&"']/g, c => ({
      '<':'&lt;','>':'&gt;','&':'&amp;','"':'&quot;',"'":'&#39;'
    })[c]);
  }

  function renderCard(s) {
    const catSlug = CAT_TO_SLUG[s.category] || 'other';
    const citySlug = regionToSlug(s.region);
    const contacts = [];
    if (s.email) contacts.push(`<a href="mailto:${escapeHtml(s.email)}">Email</a>`);
    if (s.phone) {
      const cleanPhone = (s.phone || '').replace(/\s+/g, '');
      contacts.push(`<a href="tel:${escapeHtml(cleanPhone)}">Call</a>`);
    }
    if (s.link) contacts.push(`<a href="${escapeHtml(s.link)}" target="_blank" rel="noopener">Website</a>`);

    return `
      <div class="service-card" data-cat="${catSlug}" data-city="${citySlug}">
        <div class="service-card-body">
          <div class="service-card-cat">${escapeHtml(s.category)}</div>
          <h4>${escapeHtml(s.name)}</h4>
          <p>${escapeHtml(s.description)}</p>
          ${s.languages ? `<p class="service-langs"><strong>Languages:</strong> ${escapeHtml(s.languages)}</p>` : ''}
          <div class="service-card-meta">
            <span>${escapeHtml(s.region)}</span>
            <span class="badge">Community-listed</span>
          </div>
          ${contacts.length ? `<div class="service-contacts">${contacts.join('')}</div>` : ''}
        </div>
      </div>
    `;
  }

  function getCheckedCities() {
    return [...document.querySelectorAll('.city-filter input:checked')].map(i => i.value);
  }

  function applySort(items) {
    const mode = (document.getElementById('sort-select') || {}).value || 'newest';
    const out = [...items];
    if (mode === 'alpha') {
      out.sort((a, b) => (a.name || '').localeCompare(b.name || ''));
    } else {
      out.sort((a, b) => new Date(b.created_at || 0) - new Date(a.created_at || 0));
    }
    return out;
  }

  function filterCards() {
    const grid = document.getElementById('cards-grid');
    const countEl = document.getElementById('results-count');
    if (!grid) return;

    const q = (document.getElementById('search-input').value || '').toLowerCase().trim();
    const cities = getCheckedCities();

    const filtered = allServices.filter(s => {
      const slug = CAT_TO_SLUG[s.category] || 'other';
      if (currentCat !== 'all' && slug !== currentCat) return false;
      if (cities.length === 0) return false;
      if (!cities.includes(regionToSlug(s.region))) return false;
      if (q) {
        const haystack = [s.name, s.description, s.region, s.languages, s.category].join(' ').toLowerCase();
        if (!haystack.includes(q)) return false;
      }
      return true;
    });

    const sorted = applySort(filtered);

    if (sorted.length === 0) {
      grid.innerHTML = '<p class="no-results">No services match your filters yet.</p>';
    } else {
      grid.innerHTML = sorted.map(renderCard).join('');
    }

    countEl.innerHTML = `Showing <strong>${sorted.length}</strong> of ${allServices.length} service${allServices.length === 1 ? '' : 's'}`;
  }

  function setCat(btn, cat) {
    currentCat = cat;
    document.querySelectorAll('.sidebar-link').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    filterCards();
  }

  function updateCategoryCounts() {
    const counts = { all: allServices.length };
    Object.values(CAT_TO_SLUG).forEach(slug => { counts[slug] = 0; });
    allServices.forEach(s => {
      const slug = CAT_TO_SLUG[s.category] || 'other';
      counts[slug] = (counts[slug] || 0) + 1;
    });
    document.querySelectorAll('[data-count]').forEach(el => {
      const k = el.dataset.count;
      el.textContent = counts[k] || 0;
    });
  }

  async function loadServices() {
    const grid = document.getElementById('cards-grid');
    const countEl = document.getElementById('results-count');
    const result = await supabase
      .from('services')
      .select('id, category, name, description, region, languages, email, phone, link, created_at')
      .eq('approved', true)
      .order('created_at', { ascending: false });

    if (result.error) {
      console.error('Failed to load services:', result.error);
      grid.innerHTML = '<p class="no-results">Could not load services. Please refresh the page.</p>';
      countEl.innerHTML = '<strong>0</strong> services';
      return;
    }

    allServices = result.data || [];

    if (allServices.length === 0) {
      grid.innerHTML = '<p class="no-results">No services listed yet. Be the first — list yours below.</p>';
      countEl.innerHTML = '<strong>0</strong> services yet';
      updateCategoryCounts();
      return;
    }

    updateCategoryCounts();
    filterCards();
  }

  /* ========== Form submit (Supabase insert) ========== */
  async function submitForm(e) {
    e.preventDefault();
    const form = document.getElementById('register-form');
    const errorBanner = document.getElementById('form-error-banner');
    const submitBtn = document.getElementById('submit-btn');

    errorBanner.style.display = 'none';

    // Manual validation since the form has novalidate
    const required = form.querySelectorAll('[required]');
    let valid = true;
    required.forEach(el => {
      if (!el.value || (el.type === 'checkbox' && !el.checked)) {
        el.style.borderColor = 'var(--error)';
        valid = false;
      } else {
        el.style.borderColor = '';
      }
    });
    if (!valid) {
      errorBanner.textContent = 'Please fill in all required fields and accept the agreement.';
      errorBanner.style.display = 'block';
      errorBanner.scrollIntoView({ behavior: 'smooth', block: 'center' });
      return;
    }

    submitBtn.disabled = true;
    const originalLabel = submitBtn.innerHTML;
    submitBtn.innerHTML = 'Submitting…';

    const fName = document.getElementById('f-name').value.trim();
    const fService = document.getElementById('f-service').value.trim();
    const fDesc = document.getElementById('f-desc').value.trim();
    const fLink = document.getElementById('f-link').value.trim();

    // Map design's form fields to my DB schema:
    //   DB.name        ← f-service (the service title shown on the card)
    //   DB.description ← f-desc + signature line "— [full name]"
    //   DB.region      ← f-city
    //   DB.category    ← f-cat
    //   DB.languages   ← f-languages
    //   DB.email       ← f-email
    //   DB.phone       ← f-phone (nullable)
    //   DB.link        ← f-link (nullable)
    const row = {
      name: fService,
      description: fDesc + (fName ? `\n\n— ${fName}` : ''),
      region: document.getElementById('f-city').value.trim(),
      category: document.getElementById('f-cat').value.trim(),
      languages: document.getElementById('f-languages').value.trim(),
      email: document.getElementById('f-email').value.trim(),
      phone: document.getElementById('f-phone').value.trim() || null,
      link: fLink || null
    };

    const { error } = await supabase.from('services').insert(row);

    submitBtn.disabled = false;
    submitBtn.innerHTML = originalLabel;

    if (error) {
      console.error('Supabase insert error:', error);
      errorBanner.textContent = 'Sorry — submission failed. Please try again, or email hello@geosin.be if it keeps failing.';
      errorBanner.style.display = 'block';
      errorBanner.scrollIntoView({ behavior: 'smooth', block: 'center' });
      return;
    }

    document.getElementById('register-form-card').style.display = 'none';
    document.getElementById('form-success').style.display = 'block';
    document.getElementById('form-success').scrollIntoView({ behavior: 'smooth', block: 'center' });
  }

  /* ========== Init ========== */
  (function() {
    const lang = localStorage.getItem('geosin-lang') || 'en';
    setLang(lang);

    // Apply ?cat= URL param for deep linking from footer
    const params = new URLSearchParams(location.search);
    const cat = params.get('cat');
    if (cat) {
      const btn = document.querySelector(`.sidebar-link[data-cat="${cat}"]`);
      if (btn) {
        document.querySelectorAll('.sidebar-link').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        currentCat = cat;
      }
    }

    // Scroll to register if hash present
    if (location.hash === '#register') {
      setTimeout(() => document.getElementById('register').scrollIntoView({ behavior: 'smooth' }), 200);
    }

    loadServices();
  })();
</script>
</body>
</html>
