  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="stylesheet" href="style.css" />
  <style>
    .services-layout {
      display: grid;
      grid-template-columns: 220px 1fr;
      gap: 40px;
      align-items: start;
    }
    .sidebar {
      position: sticky;
      top: calc(var(--nav-h) + 24px);
      background: var(--canvas);
      border: 1px solid var(--hairline);
      border-radius: var(--r-md);
      padding: 20px;
    }
    .sidebar h5 {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.8px;
      color: var(--muted);
      margin-bottom: 10px;
    }
    .sidebar-links { display: flex; flex-direction: column; gap: 2px; }
    .sidebar-link {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 8px 10px;
      border-radius: var(--r-sm);
      font-size: 14px;
      color: var(--body-text);
      cursor: pointer;
      transition: background 0.12s, color 0.12s;
      border: none;
      background: none;
      width: 100%;
      text-align: left;
    }
    .sidebar-link:hover { background: var(--surface); color: var(--ink); }
    .sidebar-link.active { background: var(--ink); color: #fff; }
    .sidebar-link .count {
      font-size: 11px;
      background: var(--surface);
      color: var(--muted);
      padding: 2px 7px;
      border-radius: var(--r-full);
    }
    .sidebar-link.active .count { background: rgba(255,255,255,0.2); color: rgba(255,255,255,0.8); }
    .sidebar-divider { border: none; border-top: 1px solid var(--hairline); margin: 14px 0; }
    .city-filter { display: flex; flex-direction: column; gap: 6px; margin-top: 6px; }
    .city-check { display: flex; align-items: center; gap: 8px; font-size: 14px; color: var(--body-text); cursor: pointer; }
    .city-check input { accent-color: var(--rausch); width: 15px; height: 15px; cursor: pointer; }
    .search-bar-sm {
      display: flex;
      align-items: center;
      gap: 8px;
      border: 1px solid var(--hairline);
      border-radius: var(--r-sm);
      padding: 10px 14px;
      margin-bottom: 20px;
      transition: border-color 0.15s;
    }
    .search-bar-sm:focus-within { border-color: var(--ink); border-width: 2px; }
    .search-bar-sm input {
      border: none;
      outline: none;
      font-size: 14px;
      color: var(--ink);
      width: 100%;
      background: none;
    }
    .results-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 20px;
    }
    .results-count { font-size: 14px; color: var(--muted); }
    .sort-select {
      font-size: 13px;
      color: var(--body-text);
      border: 1px solid var(--hairline);
      border-radius: var(--r-sm);
      padding: 6px 10px;
      background: var(--canvas);
      outline: none;
      cursor: pointer;
    }
    .service-card-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
    }
    .no-results {
      grid-column: 1/-1;
      text-align: center;
      padding: 60px 0;
      color: var(--muted);
    }
    .loading-state {
      grid-column: 1/-1;
      text-align: center;
      padding: 60px 0;
      color: var(--muted);
      font-size: 14px;
    }
    /* Service card body — adjusted because we don't have card images for dynamic data */
    .service-card { display: flex; flex-direction: column; }
    .service-card-body { padding: 22px 22px 20px; }
    .service-contacts { margin-top: 12px; padding-top: 12px; border-top: 1px solid var(--hairline); display: flex; gap: 14px; flex-wrap: wrap; }
    .service-contacts a { color: var(--rausch); font-size: 13px; font-weight: 600; text-decoration: none; }
    .service-contacts a:hover { text-decoration: underline; }
    .service-langs { font-size: 12px; color: var(--muted); margin-top: 6px; }
    /* Register form section */
    .register-section {
      background: var(--surface);
      border-top: 3px solid var(--rausch);
    }
    .register-intro { max-width: 520px; margin-bottom: 40px; }
    .register-intro h2 { margin-bottom: 10px; }
    .register-intro p { color: var(--body-text); }
    .form-success {
      display: none;
      background: #e6f4ea;
      border: 1px solid #c3e6cb;
      border-radius: var(--r-md);
      padding: 24px 28px;
      color: #1a7f37;
      font-size: 15px;
    }
    .form-error-banner {
      display: none;
      background: #fde7e9;
      border: 1px solid #f5b5bc;
      border-radius: var(--r-md);
      padding: 16px 22px;
      color: var(--error);
      font-size: 14px;
      margin-bottom: 20px;
    }
    @media (max-width: 900px) {
      .services-layout { grid-template-columns: 1fr; }
      .sidebar { position: static; }
      .service-card-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 560px) {
      .service-card-grid { grid-template-columns: 1fr; }
    }
  </style>
